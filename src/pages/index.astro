---
import Landing from '../layouts/Landing.astro';
import Nav from '../components/landing/Nav.astro';
import Hero from '../components/landing/Hero.astro';
import StatStrip from '../components/landing/StatStrip.astro';
import FeatureGrid from '../components/landing/FeatureGrid.astro';
import Comparison from '../components/landing/Comparison.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import QuickStart from '../components/landing/QuickStart.astro';
import FooterCta from '../components/landing/FooterCta.astro';
import Footer from '../components/landing/Footer.astro';
---

<Landing
  title="AIOS — Turn individual agent work into trusted team memory"
  description="AIOS gives every person a private agent workspace, then helps the team promote verified work into one shared brain. Open source, self-hosted, and built around explicit tiers."
>
  <Nav />
  <main>
    <Hero />
    <StatStrip />
    <FeatureGrid />
    <Comparison />
    <HowItWorks />
    <QuickStart />
    <FooterCta />
  </main>
  <Footer />
</Landing>
