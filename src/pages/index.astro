---
import Landing from '../layouts/Landing.astro';
import Nav from '../components/landing/Nav.astro';
import Hero from '../components/landing/Hero.astro';
import StatStrip from '../components/landing/StatStrip.astro';
import Problem from '../components/landing/Problem.astro';
import FeatureGrid from '../components/landing/FeatureGrid.astro';
import Integration from '../components/landing/Integration.astro';
import Transition from '../components/landing/Transition.astro';
import Comparison from '../components/landing/Comparison.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import Vision from '../components/landing/Vision.astro';
import Roadmap from '../components/landing/Roadmap.astro';
import QuickStart from '../components/landing/QuickStart.astro';
import FooterCta from '../components/landing/FooterCta.astro';
import Footer from '../components/landing/Footer.astro';
---

