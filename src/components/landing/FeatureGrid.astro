---
import { FolderTree, Network, Layers, Bot, Plug, BookOpen } from 'lucide-astro';

const cards = [
  {
    icon: FolderTree,
    headline: 'A private workspace per person.',
    body: 'Each contributor gets a numbered folder spine, workspace memory, governance rules, validators, and agent harnesses. Capture rough work locally before anything becomes team memory.',
  },
  {
    icon: Network,
    headline: 'One brain for the team.',
    body: 'Team-tier work from every workspace lands in a shared brain. It surfaces tasks, decisions, deliverables, and grounded answers across the context people chose to promote.',
  },
  {
    icon: Layers,
    headline: 'Promotion, not leakage.',
    body: 'Private → team → external is built into the files, hooks, CLI, API, and dashboard. Admin-tier content stays local; the brain rejects it at the boundary.',
  },
  {
    icon: Bot,
    headline: 'Verified harnesses, not prompt piles.',
    body: 'Turn transcripts into decisions, audit scope drift, and synthesize the week with verifier-gated workflows. AIOS treats agent output as work that must be grounded.',
  },
  {
    icon: Plug,
    headline: 'A sync contract, not a vibe.',
    body: 'Workspace and Team Brain build against one pinned brain-api contract. Version it, diff it, and keep every push predictable.',
  },
  {
    icon: BookOpen,
    headline: 'Yours to run and extend.',
    body: 'Open source, self-hosted, and plain-file first. Bring your own agent runtime, add your own harnesses, and keep your team memory in infrastructure you control.',
  },
];
---

<section class="py-20 md:py-32 bg-background">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14">
      <span class="text-label text-accent block mb-4">The system</span>
      <h2 class="text-heading-2 text-foreground max-w-[620px]">Private workspaces. Verified work. Shared brain.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {cards.map(({ icon: Icon, headline, body }) => (
        <div class="feature-card">
          <div class="mb-4 text-primary">
            <Icon size={22} />
          </div>
          <h3 class="text-heading-3 text-foreground mb-3">{headline}</h3>
          <p class="text-body text-muted-foreground">{body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
