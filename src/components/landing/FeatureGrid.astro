---
import Placeholder from './Placeholder.astro';

const cards = [
  {
    headline: 'Your workspace, your rules.',
    body: 'A numbered folder spine, governance rules, validators, and multi-agent harnesses — one per person. You decide what leaves your machine.',
    featured: true,
  },
  {
    headline: 'Shared memory, managed context.',
    body: 'Every workspace pushes tier-tagged context to one brain. Ask it questions in plain English across the team\'s shared memory. Self-host on your own Postgres.',
  },
  {
    headline: 'Nothing leaks without a push.',
    body: 'Private → team → external. You promote content deliberately through the spine, and the brain rejects admin-tier at the boundary. Audience tags are first-class, not afterthoughts.',
  },
  {
    headline: 'Automated workflows, delivered.',
    body: 'Turn meeting transcripts into decisions. Run weekly synthesis. Catch scope creep. Harnesses that ship deliverables, not chat logs.',
  },
  {
    headline: 'All your tools in one place.',
    body: 'Slack, GitHub, Linear, Notion, Granola and more—wired into your workspace via MCP and CLI, with Team Brain sync where the integration supports it.',
  },
  {
    headline: 'Yours to run, start to finish.',
    body: 'Open source under MIT. Self-host the brain, clone the workspace per person. No cloud, no lock-in, no per-seat pricing.',
  },
];
---

<section class="relative py-20 md:py-32 bg-background">
  <div class="relative z-10 max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14">
      <span class="text-label text-muted-foreground block mb-4">The system</span>
      <h2 class="text-heading-2 text-foreground max-w-[540px]">A workspace for individuals, a brain for the team.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {cards.map(({ headline, body, featured }) => (
        <div class={`feature-card feature-card--media flex flex-col${featured ? ' feature-card--featured' : ''}`}>
          <div class="card-media card-media--16x9">
            <Placeholder fill variant="illustration" label={headline} />
          </div>
          <div class="card-body flex flex-col flex-1">
            <h3 class="text-heading-3 text-foreground mb-2">{headline}</h3>
            <p class="text-body text-muted-foreground">{body}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
