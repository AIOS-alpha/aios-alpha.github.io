---
import { FolderTree, Network, Layers, Bot, Plug, BookOpen } from 'lucide-astro';

const cards = [
  {
    icon: FolderTree,
    headline: 'Your workspace, your rules.',
    body: 'A numbered folder spine, governance rules, validators, and multi-agent harnesses — one per person. You decide what leaves your machine.',
  },
  {
    icon: Network,
    headline: 'Shared memory, without the noise.',
    body: 'Every workspace pushes tier-tagged context to one brain. Ask it questions in plain English across the team\'s shared memory. Self-host on your own Supabase.',
  },
  {
    icon: Layers,
    headline: 'Nothing leaks without a push.',
    body: 'Private → team → external. You promote content deliberately through the spine, and the brain rejects admin-tier at the boundary. Audience tags are first-class, not afterthoughts.',
  },
  {
    icon: Bot,
    headline: 'Real work, not wrappers.',
    body: 'Turn meeting transcripts into decisions. Run weekly synthesis. Catch scope creep. Harnesses that ship deliverables, not chat logs.',
  },
  {
    icon: Plug,
    headline: 'A contract, not a vibe.',
    body: 'Both repos build against one pinned brain-api spec. Version it, diff it, and never break a push silently.',
  },
  {
    icon: BookOpen,
    headline: 'Yours to run, start to finish.',
    body: 'Open source under MIT. Self-host the brain, clone the workspace per person. No cloud, no lock-in, no per-seat pricing.',
  },
];
---

<section class="py-20 md:py-32 bg-background">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14">
      <span class="text-label text-accent block mb-4">The system</span>
      <h2 class="text-heading-2 text-foreground max-w-[540px]">Two repos. One system.</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {cards.map(({ icon: Icon, headline, body }) => (
        <div class="feature-card">
          <div class="mb-4 text-primary">
            <Icon size={22} />
          </div>
          <h3 class="text-heading-3 text-foreground mb-3">{headline}</h3>
          <p class="text-body text-muted-foreground">{body}</p>
        </div>
      ))}
    </div>

  </div>
</section>
