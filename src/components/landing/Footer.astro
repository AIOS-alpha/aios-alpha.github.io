---
import AiosLogo from './AiosLogo.astro';
---

<footer class="bg-surface border-t border-border">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20 py-16">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">

      <!-- Wordmark column -->
      <div class="md:col-span-1">
        <a href="/" class="flex items-center no-underline mb-4 text-foreground">
          <AiosLogo markClass="!w-7 !h-7" />
        </a>
        <p class="text-small text-muted-foreground max-w-[220px]">
          Structured agent workspaces and a shared team brain. MIT-licensed.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-label text-foreground mb-4">Product</h4>
        <ul class="space-y-3">
          <li><a href="/guides/workspace" class="link-underline text-small text-muted-foreground hover:text-foreground transition-colors duration-200 no-underline">Workspace</a></li>
          <li><a href="/guides/team-brain" class="link-underline text-small text-muted-foreground hover:text-foreground transition-colors duration-200 no-underline">Team Brain</a></li>
          <li><a href="/guides/quickstart" class="link-underline text-small text-muted-foreground hover:text-foreground transition-colors duration-200 no-underline">Docs</a></li>
          <li><a href="/deck/" class="link-underline text-small text-muted-foreground hover:text-foreground transition-colors duration-200 no-underline">Product deck ↗</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h4 class="text-label text-foreground mb-4">Community</h4>
        <ul class="space-y-3">
          <li>
            <a
              href="https://github.com/AIOS-alpha"
              target="_blank"
              rel="noopener noreferrer"
              class="link-underline text-small text-muted-foreground hover:text-foreground transition-colors duration-200 no-underline"
            >
              GitHub
            </a>
          </li>
          <li><a href="/contributing" class="link-underline text-small text-muted-foreground hover:text-foreground transition-colors duration-200 no-underline">Contributing</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-label text-foreground mb-4">Legal</h4>
        <ul class="space-y-3">
          <li><a href="https://github.com/AIOS-alpha/aios-alpha.github.io/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="link-underline text-small text-muted-foreground hover:text-foreground transition-colors duration-200 no-underline">MIT License</a></li>
        </ul>
      </div>

    </div>

    <div class="pt-8 border-t border-border flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <p class="text-small text-muted-foreground">
        © 2026 AIOS contributors · MIT License
      </p>
      <p class="text-small text-muted-foreground">
        Built by
        <a href="https://github.com/john-ellison" target="_blank" rel="noopener noreferrer" class="link-underline text-foreground font-semibold hover:text-foreground transition-colors duration-200 no-underline">John Ellison</a>
        &amp;
        <a href="https://github.com/chetan-guevara" target="_blank" rel="noopener noreferrer" class="link-underline text-foreground font-semibold hover:text-foreground transition-colors duration-200 no-underline">Chetan Nandakumar</a>
        · maintained by
        <a href="https://vibrana.ai" target="_blank" rel="noopener noreferrer" class="link-underline text-foreground font-semibold hover:text-foreground transition-colors duration-200 no-underline">Vibrana</a>
      </p>
    </div>

  </div>
</footer>
