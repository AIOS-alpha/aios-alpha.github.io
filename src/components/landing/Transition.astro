---
import CollectiveBrain from './diagrams/CollectiveBrain.astro';
---

<section class="relative py-20 md:py-32">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14 max-w-[640px]">
      <span class="text-label text-muted-foreground block mb-4">HOW IT WORKS</span>
      <h2 class="text-heading-2 text-foreground mb-5">One collective brain</h2>
      <p class="text-body-lg text-muted-foreground">
        Every agent and data source feeds a single shared brain — knowledge, memory,
        reasoning, and policy in one place. It surfaces the work and acts on it,
        getting sharper with every use.
      </p>
    </div>

    <CollectiveBrain />

  </div>
</section>
