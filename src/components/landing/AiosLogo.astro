---
/* The AIOS "caret-A" mark in currentColor (via CSS mask of the mono asset),
   paired with the AIOS wordmark. Inherits text colour, so it flips ink/white
   with the theme automatically. The prism-coloured mark is reserved for the
   favicon — chrome stays greyscale (Editorial Minimal). */
interface Props {
  class?: string;
  markClass?: string;
  showWordmark?: boolean;
}
const { class: className = '', markClass = '', showWordmark = true } = Astro.props;
---

<span class={`aios-logo ${className}`} aria-label="AIOS">
  <span class={`aios-mark ${markClass}`} aria-hidden="true"></span>
  {showWordmark && <span class="aios-wordmark">AIOS</span>}
</span>

<style>
  .aios-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: inherit;
  }
  .aios-mark {
    display: inline-block;
    width: 1.5rem;
    height: 1.5rem;
    flex: none;
    background-color: currentColor;
    -webkit-mask: url('/brand/aios-mark-mono.svg') center / contain no-repeat;
    mask: url('/brand/aios-mark-mono.svg') center / contain no-repeat;
  }
  .aios-wordmark {
    font-family: var(--aios-font-sans);
    font-weight: 600;
    font-size: 1.15rem;
    letter-spacing: 0.01em;
    color: inherit;
  }
</style>
