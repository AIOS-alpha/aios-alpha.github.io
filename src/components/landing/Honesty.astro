---
const problems = [
  {
    num: '01',
    title: 'Context overload',
    body: 'Too many signals, too much noise. Attention and prioritization are the hardest design challenge. A brain that pages you about everything is worse than no brain at all.',
  },
  {
    num: '02',
    title: 'Contribution incentives',
    body: 'The system is only as good as what people push. Social design matters as much as technical design — tier tags and governance only work when the team participates.',
  },
  {
    num: '03',
    title: 'Governance',
    body: 'Building a coordination system requires coordinating the builders. Early decisions set the cultural tone permanently — policy defaults and approval flows are not afterthoughts.',
  },
  {
    num: '04',
    title: 'Trust in autonomous agents',
    body: 'Earned incrementally. Start narrow, demonstrate reliability on team-tier work, then expand scope. The action layer stays policy-gated for a reason.',
  },
  {
    num: '05',
    title: 'The schema problem',
    body: 'What is the unit of knowledge? How information is represented decides whether the whole thing is queryable or just a fancier search index. OKF and tier-tagged items are our bet.',
  },
];
---

<section id="honesty" class="relative py-20 md:py-32 bg-surface">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14 max-w-[660px]">
      <span class="text-label text-muted-foreground block mb-4">Honesty</span>
      <h2 class="text-heading-2 text-foreground mb-5">The hard problems we're solving in the open.</h2>
      <p class="text-body-lg text-muted-foreground">
        A collective brain is not a solved problem. These are the design challenges
        we track publicly — and the reason architecture choices matter from the start.
      </p>
    </div>

    {/* Lead problem — full-width featured row, split title / body across the width */}
    <article class="group border-t border-border pt-8 md:pt-10 grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-12">
      <div class="lg:col-span-5 flex items-start gap-5">
        <span
          class="font-[family-name:var(--font-display)] text-5xl md:text-6xl leading-[0.85] text-muted-foreground/30 tabular-nums select-none"
          aria-hidden="true"
        >
          {problems[0].num}
        </span>
        <h3 class="text-heading-3 text-foreground pt-1">{problems[0].title}</h3>
      </div>
      <p class="lg:col-span-7 text-body-lg text-muted-foreground max-w-[60ch]">
        {problems[0].body}
      </p>
    </article>

    {/* Remaining problems — 2-column editorial index, hairline dividers, no boxes */}
    <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-x-12 lg:gap-x-20">
      {problems.slice(1).map(({ num, title, body }) => (
        <article class="group border-t border-border pt-7 md:pt-8 pb-2 flex items-start gap-5">
          <span
            class="font-[family-name:var(--font-display)] text-4xl md:text-5xl leading-[0.85] text-muted-foreground/30 tabular-nums select-none shrink-0"
            aria-hidden="true"
          >
            {num}
          </span>
          <div class="min-w-0">
            <h3 class="text-heading-3 text-foreground mb-2">{title}</h3>
            <p class="text-body text-muted-foreground">{body}</p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
