---
---

<section class="py-20 md:py-32 bg-background">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14">
      <span class="text-label text-accent block mb-4">Getting started</span>
      <h2 class="text-heading-2 text-foreground">Run the operating loop once.</h2>
    </div>

    <div class="terminal max-w-[720px]">
      <div class="terminal-header" aria-hidden="true">
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="text-label text-muted-foreground ml-2">bash</span>
      </div>
      <div class="terminal-body space-y-5">

        <div>
          <div class="terminal-comment mb-1"># 1. Scaffold your private workspace</div>
          <div><span class="terminal-prompt">$</span> git clone https://github.com/AIOS-alpha/aios-workspace</div>
          <div><span class="terminal-prompt">$</span> cd aios-workspace</div>
          <div><span class="terminal-prompt">$</span> ./scripts/scaffold-project.sh --slug alex-aios --owner alex</div>
        </div>

        <div>
          <div class="terminal-comment mb-1"># 2. Run a verifier-gated harness in Claude Code</div>
          <div><span class="terminal-prompt">$</span> cd ~/Projects/alex-aios</div>
          <div><span class="terminal-prompt">$</span> /weekly-synthesis</div>
        </div>

        <div>
          <div class="terminal-comment mb-1"># 3. Review what can leave your machine</div>
          <div><span class="terminal-prompt">$</span> aios status</div>
          <div><span class="terminal-prompt">$</span> aios push</div>
        </div>

      </div>
    </div>

    <div class="mt-8">
      <a
        href="/guides/quickstart"
        class="text-body text-link hover:text-primary transition-colors duration-200 no-underline"
      >
        Read the full quickstart →
      </a>
    </div>

  </div>
</section>
