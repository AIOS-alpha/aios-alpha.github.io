---
---

<section class="py-20 md:py-32 bg-background">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14">
      <span class="text-label text-accent block mb-4">Getting started</span>
      <h2 class="text-heading-2 text-foreground">Up in three commands.</h2>
    </div>

    <div class="terminal max-w-[720px]">
      <div class="terminal-header" aria-hidden="true">
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="text-label text-muted-foreground ml-2">bash</span>
      </div>
      <div class="terminal-body space-y-5">

        <div>
          <div class="terminal-comment mb-1"># 1. Initialize your workspace</div>
          <div><span class="terminal-prompt">$</span> npx aios-init my-workspace</div>
        </div>

        <div>
          <div class="terminal-comment mb-1"># 2. Run your first harness</div>
          <div><span class="terminal-prompt">$</span> aios run meeting-synthesis --input ./transcripts/</div>
        </div>

        <div>
          <div class="terminal-comment mb-1"># 3. Push to the team brain</div>
          <div><span class="terminal-prompt">$</span> aios push --tier team</div>
        </div>

      </div>
    </div>

    <div class="mt-8">
      <a
        href="/guides/quickstart"
        class="text-body text-link hover:text-primary transition-colors duration-200 no-underline"
      >
        Read the full guide →
      </a>
    </div>

  </div>
</section>
