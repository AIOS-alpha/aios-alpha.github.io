---
const boxes = [
  {
    n: '01',
    title: 'Individual Workspace',
    items: [
      ['private/', 'stays local'],
      ['team/', 'gets pushed'],
      ['external/', 'goes to docs'],
    ],
  },
  {
    n: '02',
    title: 'Team Brain API',
    items: [
      [null, 'Validates tier at boundary'],
      ['admin', 'tier rejected (422)'],
      [null, 'Versioned sync contract'],
    ],
  },
  {
    n: '03',
    title: 'Shared Dashboard',
    items: [
      [null, 'Natural-language Q&A'],
      [null, 'Task & decision surfacing'],
      [null, 'Cross-workspace synthesis'],
    ],
  },
];
---

<section class="py-20 md:py-32 bg-surface">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14">
      <span class="text-label text-muted-foreground block mb-4">Architecture</span>
      <h2 class="text-heading-2 text-foreground">How information flows</h2>
    </div>

    <!-- Flow diagram -->
    <div class="flex flex-col md:flex-row items-stretch md:items-center gap-4 md:gap-0 mb-16">
      {boxes.map((box, i) => (
        <>
          <div class="flex-1 bg-surface-elevated border border-border rounded-xl p-6">
            <div class="text-label text-muted-foreground mb-2">{box.n}</div>
            <div class="text-heading-3 text-foreground mb-4">{box.title}</div>
            <ul class="space-y-1.5">
              {box.items.map(([code, text]) => (
                <li class="text-small text-muted-foreground flex items-start gap-2">
                  <span class="text-foreground/40 mt-0.5 shrink-0">·</span>
                  <span>{code && <code class="text-code text-foreground">{code}</code>} {text}</span>
                </li>
              ))}
            </ul>
          </div>
          {i < boxes.length - 1 && (
            <div class="flow-arrow justify-center md:flex-col md:items-center px-4 py-2 md:py-0">
              <span class="text-small text-muted-foreground hidden md:block mb-1">{i === 0 ? 'push' : 'ingest'}</span>
              <svg class="md:rotate-0 rotate-90" width="32" height="16" viewBox="0 0 32 16" fill="none" aria-hidden="true">
                <path d="M0 8H28M28 8L21 1M28 8L21 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </>
      ))}
    </div>

    <!-- Code split -->
    <div class="code-split">

      <!-- Left: brain-api.md snippet -->
      <div class="terminal">
        <div class="terminal-header" aria-hidden="true">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="text-label terminal-label ml-2">brain-api.md (v1 contract)</span>
        </div>
        <div class="terminal-body">
          <div class="terminal-comment"># POST /v1/push</div>
          <div class="terminal-comment"># Content-Type: application/json</div>
          <div class="mt-2">{`{`}</div>
          <div>&nbsp;&nbsp;<span class="terminal-key">"tier"</span>: <span class="terminal-prompt">"team"</span>,</div>
          <div>&nbsp;&nbsp;<span class="terminal-key">"workspace_id"</span>: <span class="terminal-prompt">"ws_abc123"</span>,</div>
          <div>&nbsp;&nbsp;<span class="terminal-key">"content"</span>: {`[...]`}</div>
          <div>{`}`}</div>
          <div class="mt-2 terminal-comment"># 422 if tier == "admin"</div>
        </div>
      </div>

      <!-- Right: aios push terminal output -->
      <div class="terminal">
        <div class="terminal-header" aria-hidden="true">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="text-label terminal-label ml-2">terminal — aios push</span>
        </div>
        <div class="terminal-body">
          <div><span class="terminal-prompt">$</span> aios push --tier team</div>
          <div class="mt-2 terminal-comment">→ scanning 2-work/ for team-tier content</div>
          <div class="terminal-comment">→ found 4 files to push</div>
          <div class="terminal-comment">→ validating against brain-api v1</div>
          <div class="mt-2 terminal-success">✓ pushed 4 files to team brain</div>
          <div class="terminal-success">✓ sync complete (847ms)</div>
        </div>
      </div>

    </div>

  </div>
</section>
