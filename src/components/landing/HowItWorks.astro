---
---

<section class="py-20 md:py-32 bg-surface">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14">
      <span class="text-label text-accent block mb-4">Operating loop</span>
      <h2 class="text-heading-2 text-foreground">How private agent work becomes team memory</h2>
    </div>

    <!-- Flow diagram -->
    <div class="flex flex-col md:flex-row items-stretch md:items-center gap-4 md:gap-0 mb-16">

      <!-- Box 1 -->
      <div class="flex-1 bg-surface-elevated border border-border-visible rounded-xl p-6">
        <div class="text-label text-accent mb-1">01</div>
        <div class="text-heading-3 text-foreground mb-4">Capture locally</div>
        <ul class="space-y-1.5">
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>rough notes and drafts stay local</span>
          </li>
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>harnesses produce grounded artifacts</span>
          </li>
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>tiers are written into frontmatter</span>
          </li>
        </ul>
      </div>

      <!-- Arrow -->
      <div class="flow-arrow justify-center md:flex-col md:items-center px-4 py-2 md:py-0">
        <span class="text-small text-muted-foreground hidden md:block mb-1">review</span>
        <svg class="md:rotate-0 rotate-90" width="32" height="16" viewBox="0 0 32 16" fill="none" aria-hidden="true">
          <path d="M0 8H28M28 8L21 1M28 8L21 15" stroke="#84cc16" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Box 2 -->
      <div class="flex-1 bg-surface-elevated border border-border-visible rounded-xl p-6">
        <div class="text-label text-accent mb-1">02</div>
        <div class="text-heading-3 text-foreground mb-4">Promote deliberately</div>
        <ul class="space-y-1.5">
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>preview what would sync</span>
          </li>
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>block <code class="text-code text-link">admin</code> tier before network</span>
          </li>
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>push only team or external work</span>
          </li>
        </ul>
      </div>

      <!-- Arrow -->
      <div class="flow-arrow justify-center md:flex-col md:items-center px-4 py-2 md:py-0">
        <span class="text-small text-muted-foreground hidden md:block mb-1">query</span>
        <svg class="md:rotate-0 rotate-90" width="32" height="16" viewBox="0 0 32 16" fill="none" aria-hidden="true">
          <path d="M0 8H28M28 8L21 1M28 8L21 15" stroke="#84cc16" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <!-- Box 3 -->
      <div class="flex-1 bg-surface-elevated border border-border-visible rounded-xl p-6">
        <div class="text-label text-accent mb-1">03</div>
        <div class="text-heading-3 text-foreground mb-4">Query the brain</div>
        <ul class="space-y-1.5">
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>ask grounded team questions</span>
          </li>
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>surface tasks and decisions</span>
          </li>
          <li class="text-small text-muted-foreground flex items-start gap-2">
            <span class="text-accent mt-0.5 shrink-0">·</span>
            <span>synthesize across workspaces</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Code split -->
    <div class="code-split">

      <!-- Left: brain-api.md snippet -->
      <div class="terminal">
        <div class="terminal-header" aria-hidden="true">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="text-label text-muted-foreground ml-2">brain-api.md (contract)</span>
        </div>
        <div class="terminal-body">
          <div class="terminal-comment"># POST /api/v1/items</div>
          <div class="terminal-comment"># one item per request</div>
          <div class="mt-2">{`{`}</div>
          <div>&nbsp;&nbsp;<span class="text-link">"project"</span>: <span class="text-accent">"my-workspace"</span>,</div>
          <div>&nbsp;&nbsp;<span class="text-link">"path"</span>: <span class="text-accent">"2-work/brief.md"</span>,</div>
          <div>&nbsp;&nbsp;<span class="text-link">"access"</span>: <span class="text-accent">"team"</span></div>
          <div>{`}`}</div>
          <div class="mt-2 terminal-comment"># 422 if access == "admin"</div>
        </div>
      </div>

      <!-- Right: aios push terminal output -->
      <div class="terminal">
        <div class="terminal-header" aria-hidden="true">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="text-label text-muted-foreground ml-2">terminal — aios push</span>
        </div>
        <div class="terminal-body">
          <div><span class="terminal-prompt">$</span> aios status</div>
          <div class="mt-2 terminal-comment">→ new: 2-work/brief.md [team]</div>
          <div class="terminal-comment">→ blocked: 5-personal/rates.md [admin]</div>
          <div><span class="terminal-prompt">$</span> aios push</div>
          <div class="mt-2 text-accent">✓ pushed 1 file to team brain</div>
          <div class="text-accent">✓ sync complete (847ms)</div>
        </div>
      </div>

    </div>

  </div>
</section>
