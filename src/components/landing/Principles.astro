---
import PrinciplesMatrix from './diagrams/PrinciplesMatrix.astro';
---

<section id="principles" class="relative py-20 md:py-32 bg-background">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-14 max-w-[620px]">
      <span class="text-label text-muted-foreground block mb-4">Principles</span>
      <h2 class="text-heading-2 text-foreground mb-5">Built for teams, not just individuals.</h2>
      <p class="text-body-lg text-muted-foreground">
        AIOS is a coordination layer — modular organs you can adopt piece by piece,
        with permission and privacy baked into the architecture from day one.
      </p>
    </div>

    <PrinciplesMatrix />

  </div>
</section>
