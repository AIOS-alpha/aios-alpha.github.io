const streams = [
  { name: 'Slack',   ...ICONS.slack },
  { name: 'Notion',  ...ICONS.notion },
  { name: 'Linear',  ...ICONS.linear },
  { name: 'GitHub',  ...ICONS.github },
  { name: 'Granola', ...ICONS.granola },
  { name: 'Google',  ...ICONS.google },
];
const COLS = ['10.9%', '19.9%'];
const ROWS = ['59.4%', '68.1%', '76.9%'];

/* Agent-users: a real person paired with the AI tool they drive — the
   "human + AI = agent-user" dynamic. The headshot auto-appears once a square
   `public/agents/<slug>.webp` is dropped in; until then an initials chip shows.
   Small monochrome tool glyphs (currentColor) echo the integration logo style. */
import { existsSync } from 'node:fs';
const face = (slug) => (existsSync(`public/agents/${slug}.webp`) ? `/agents/${slug}.webp` : null);
const TOOL_GLYPH = {
  // Claude — 4-point sparkle
  claude: '<path d="M12 2c.45 4.7 2.3 6.55 7 7-4.7.45-6.55 2.3-7 7-.45-4.7-2.3-6.55-7-7 4.7-.45 6.55-2.3 7-7Z"/>',
  // Cursor — pointer
  cursor: '<path d="M5 3l13.5 7.8-5.7.9-2.2 5.8L5 3Z"/>',
  // Composer / Conductor — waveform
  wave: '<g><rect x="3.5" y="9.5" width="2.4" height="5" rx="1.2"/><rect x="8" y="5.5" width="2.4" height="13" rx="1.2"/><rect x="12.5" y="7.5" width="2.4" height="9" rx="1.2"/><rect x="17" y="10" width="2.4" height="4" rx="1.2"/></g>',
};
const agentUsers = [
  { slug: 'john',   name: 'John',   tool: 'Claude Code', glyph: 'claude', initials: 'J', top: '15.5%' },
  { slug: 'chetan', name: 'Chetan', tool: 'Conductor',   glyph: 'wave',   initials: 'C', top: '30.5%' },
  { slug: 'fatma',  name: 'Fatma',  tool: 'Cursor',      glyph: 'cursor', initials: 'F', top: '45.5%' },
];
---

<figure class="cbrain dgm" aria-labelledby="cbrain-cap">
  <p class="sr-only" id="cbrain-cap">
    Agent-users on Claude Code, Cursor and the AIOS Workstation send daily
    updates, and data streams from Slack, Notion, Linear, GitHub, Granola,
    Google and more are ingested, into one Team Brain holding knowledge, memory,
    reasoning and policy. A context engine beneath it finds patterns and closes
    the loop. The brain surfaces a kanban board, a KPI dashboard and a query
    interface, and takes policy-governed actions — spawning agents, executing
    tasks, and improving the team's shared harness of skills, hooks and guards.
  </p>

  <svg class="dgm-svg" viewBox="0 0 1280 800" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
    <defs>
      <marker id="cb-arrow" viewBox="0 0 10 10" refX="7" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="var(--aios-border-strong)" />
      </marker>
      <radialGradient id="cb-halo" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="var(--aios-violet)"  stop-opacity="0.22" />
        <stop offset="55%" stop-color="var(--aios-emerald)" stop-opacity="0.08" />
        <stop offset="100%" stop-color="var(--aios-accent)" stop-opacity="0" />
      </radialGradient>
    </defs>

    <!-- brain bokeh — slow "human-lungs" breathing (shared dgm-breathe; ≈12% softer) -->
    <circle class="dgm-breathe" cx="640" cy="290" r="170" fill="url(#cb-halo)" />

    <!-- inputs -> brain : agent-users + integrations, both subtle dashed
         lines animating toward the brain -->
    <path class="dgm-edge dgm-edge--faint cb-ingest" d="M305,128 C410,128 442,248 487,250" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint cb-ingest" d="M305,238 C420,238 452,273 487,275" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint cb-ingest" d="M305,348 C430,348 462,300 487,300" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint cb-ingest" d="M312,475 C400,475 442,335 487,332" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint cb-ingest" d="M312,545 C410,545 452,352 487,348" marker-end="url(#cb-arrow)" />

    <!-- brain -> surfaces -->
    <path class="dgm-edge dgm-edge--faint" d="M788,250 C880,250 900,128 975,128" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint" d="M788,275 C880,275 900,238 975,238" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint" d="M788,300 C880,300 900,348 975,348" marker-end="url(#cb-arrow)" />

    <!-- brain -> actions -->
    <path class="dgm-edge dgm-edge--faint" d="M788,325 C880,325 900,475 975,475" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint" d="M788,345 C880,345 900,585 975,585" marker-end="url(#cb-arrow)" />
    <path class="dgm-edge dgm-edge--faint" d="M788,362 C870,362 900,695 975,695" marker-end="url(#cb-arrow)" />

    <!-- Context Engine closes the loop — a clean cycle icon centered in the gap -->
    <g class="cb-cycle" transform="translate(640 414) scale(1.7) translate(-12 -12)">
      <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" />
      <path d="M21 3v5h-5" />
      <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" />
      <path d="M8 16H3v5" />
    </g>
  </svg>

  <!-- AGENT-USERS — a person + the AI tool they drive -->
  <span class="cb-label cb-label--agents" style="left:15.2%; top:8.75%;">AGENT-USERS</span>
  {agentUsers.map((a) => (
    <div class="cb-node cb-node--agent" style={`left:15.2%; top:${a.top};`}>
      <div class="dgm-node cb-tint--ic cb-agent">
        <span class="cb-agent__pair">
          {face(a.slug)
            ? <img class="cb-agent__face" src={face(a.slug)} alt="" width="40" height="40" loading="lazy" decoding="async" />
            : <span class="cb-agent__face cb-agent__face--ph" aria-hidden="true">{a.initials}</span>}
          <span class="cb-agent__plus" aria-hidden="true">+</span>
          <span class="cb-agent__tool" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="currentColor"><Fragment set:html={TOOL_GLYPH[a.glyph]} /></svg>
          </span>
        </span>
        <span class="dgm-node__title cb-agent__name">{a.name}</span>
        <span class="dgm-node__meta">{a.tool}</span>
      </div>
    </div>
  ))}

  <!-- INTEGRATIONS -->
  <span class="cb-label cb-label--streams" style="left:15.2%; top:53.75%;">INTEGRATIONS</span>
  {streams.map((s, i) => (
    <div class="cb-node cb-node--stream" style={`left:${COLS[i % 2]}; top:${ROWS[Math.floor(i / 2)]};`}>
      <div class="dgm-node cb-logo">
        <svg class="cb-logo__icon" viewBox={s.vb} aria-hidden="true"><path d={s.d} fill="currentColor" /></svg>
        <span class="cb-logo__name">{s.name}</span>
      </div>
    </div>
  ))}
  <div class="cb-node cb-node--more" style="left:15.2%; top:85.6%;">
    <div class="dgm-node dgm-node--ghost"><span class="dgm-node__meta">+ more</span></div>
  </div>

  <!-- TEAM BRAIN -->
  <div class="cb-node cb-node--brain" style="left:50%; top:36.25%;">
    <div class="dgm-node cb-brain">
      <svg class="cb-brain__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 18V5" />
        <path d="M15 13a4.17 4.17 0 0 1-3-4 4.17 4.17 0 0 1-3 4" />
        <path d="M17.598 6.5A3 3 0 1 0 12 5a3 3 0 1 0-5.598 1.5" />
        <path d="M17.997 5.125a4 4 0 0 1 2.526 5.77" />
        <path d="M18 18a4 4 0 0 0 2-7.464" />
        <path d="M19.967 17.483A4 4 0 1 1 12 18a4 4 0 1 1-7.967-.517" />
        <path d="M6 18a4 4 0 0 1-2-7.464" />
        <path d="M6.003 5.125a4 4 0 0 0-2.526 5.77" />
      </svg>
      <span class="cb-brain__title">Team Brain</span>
      <span class="cb-brain__meta">Knowledge · Memory</span>
      <span class="cb-brain__meta">Reasoning · Policy · Insights</span>
    </div>
  </div>

  <!-- CONTEXT ENGINE (closes the loop) -->
  <div class="cb-node cb-node--engine" style="left:50%; top:65.5%;">
    <div class="dgm-node cb-engine">
      <svg class="cb-engine__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M9.671 4.136a2.34 2.34 0 0 1 4.659 0 2.34 2.34 0 0 0 3.319 1.915 2.34 2.34 0 0 1 2.33 4.033 2.34 2.34 0 0 0 0 3.831 2.34 2.34 0 0 1-2.33 4.033 2.34 2.34 0 0 0-3.319 1.915 2.34 2.34 0 0 1-4.659 0 2.34 2.34 0 0 0-3.32-1.915 2.34 2.34 0 0 1-2.33-4.033 2.34 2.34 0 0 0 0-3.831A2.34 2.34 0 0 1 6.35 6.051a2.34 2.34 0 0 0 3.319-1.915" />
        <circle cx="12" cy="12" r="3" />
      </svg>
      <span class="dgm-node__title">Context Engine</span>
      <span class="dgm-node__meta">manages context · finds patterns</span>
      <span class="dgm-node__meta">shares insights</span>
    </div>
  </div>

  <!-- SURFACES -->
