---
/* A real product screenshot with light + dark sources that swap on theme.
   Mirrors Placeholder.astro's API so it drops into the same slots.

   FRAMING: echoes the shared `.dgm-frame` primitive (src/styles/diagrams.css)
   — a hairline border + a soft NEUTRAL elevation shadow (greyscale, no colour
   glow, per Editorial Minimal) — so the shot reads as a raised surface that
   separates from the section background in BOTH themes.

   - `fill`  = absolutely fill the parent `.card-media` box (which owns the
               aspect ratio + clipping and supplies the outer card border). The
               drop shadow would be clipped, so we keep a hairline inset ring so
               the shot's edge stays defined instead of stripping the border.
   - `ratio` = own aspect ratio when standalone (ignored when `fill`); gets the
               full frame: border, radius, and elevation shadow.
   Both sources are rendered and cross-toggled via opacity on `data-theme`
   (Starlight's source of truth, mirrored to `.dark` by the head script). */
interface Props {
  light: string;        // e.g. "/screenshots/integrations-light.png"
  dark: string;
  alt: string;
  ratio?: string;       // e.g. "4 / 5" — standalone only
  fill?: boolean;
  eager?: boolean;      // above-the-fold (hero) → eager-load
  label?: string;       // accepted for caller compatibility; not rendered
  class?: string;
}
const {
  light,
  dark,
  alt,
  ratio = '16 / 9',
  fill = false,
  eager = false,
  label: _label = '',
  class: className = '',
} = Astro.props;
const loading = eager ? 'eager' : 'lazy';
const fetchpriority = eager ? 'high' : 'auto';
---

<div
  class={`ss${fill ? ' ss--fill' : ''} ${className}`}
  style={`--ss-ratio:${ratio}`}
>
  <img
    class="ss-img ss-light"
    src={light}
    alt={alt}
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
  <img
    class="ss-img ss-dark"
    src={dark}
    alt=""
    aria-hidden="true"
    loading={loading}
    fetchpriority={fetchpriority}
    decoding="async"
  />
</div>

<style>
  /* Framed like .dgm-frame: hairline border + soft NEUTRAL elevation (greyscale
     token — no colour glow) so the shot lifts off the page in light and dark. */
  .ss {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ss-ratio);
    border: 1px solid var(--aios-border);
    border-radius: var(--aios-radius-xl);
    overflow: hidden;
    background: var(--aios-surface);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.04),
      0 16px 40px -24px rgba(0, 0, 0, 0.34);
    line-height: 0;
  }
  /* Fill the parent `.card-media` box (which owns the aspect ratio + clipping
     and supplies the outer card border). The drop shadow would be clipped here,
     so define the shot's edge with a hairline inset ring rather than stripping
     the border — this is the frame the fill path was missing. */
  .ss--fill {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: inset 0 0 0 1px var(--aios-border);
  }
  .ss-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: opacity 0.2s ease;
  }
  /* Light is the default; dark fades in when the theme flips. */
  .ss-dark { opacity: 0; }
  :global(:root[data-theme='dark']) .ss-light { opacity: 0; }
  :global(:root[data-theme='dark']) .ss-dark { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .ss-img { transition: none; }
  }
</style>
