---
const stats = [
  { value: '2', label: 'Repos. One system.' },
  { value: '3', label: 'Tiers. Nothing leaks.' },
  { value: '100%', label: 'Self-hosted. MIT-licensed.' },
];
---

<section class="relative py-16 stat-strip border-y border-border">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-0 md:divide-x md:divide-border">
      {stats.map(({ value, label }) => (
        <div class="flex flex-col items-center md:items-start md:px-8 first:md:pl-0 last:md:pr-0">
          <span class="text-display text-foreground leading-none">{value}</span>
          <span class="text-label text-muted-foreground mt-3">{label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
