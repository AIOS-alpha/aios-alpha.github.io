---
import { Check, Minus } from 'lucide-astro';

const rows = [
  {
    dimension: 'Who can use it',
    plain: 'Engineers comfortable living in a terminal',
    aios: 'Anyone — a UI puts the agent harnesses one click away',
  },
  {
    dimension: 'Agent harnesses',
    plain: 'Wire up the prompts and glue yourself, every time',
    aios: 'Packaged and reusable: transcripts → decisions, weekly synthesis, scope-creep detection',
  },
  {
    dimension: 'Team memory',
    plain: 'Per-repo, per-session, scattered across chats',
    aios: 'One shared brain, queried in plain English',
  },
  {
    dimension: 'Sharing & privacy',
    plain: 'All-or-nothing repo access',
    aios: 'Tiered: private → team → external. Nothing leaks without a push',
  },
  {
    dimension: 'Structure',
    plain: 'A blank repo and whatever conventions you remember',
    aios: 'A numbered workspace spine, validators, and governance per person',
  },
  {
    dimension: 'Ownership',
    plain: 'Your repos, your machines',
    aios: 'Same — MIT-licensed, self-hosted, no new cloud',
  },
];
---

<section class="py-20 md:py-32 bg-background">
  <div class="max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20">

    <div class="mb-12 max-w-[660px]">
      <span class="text-label text-accent block mb-4">The difference</span>
      <h2 class="text-heading-2 text-foreground mb-5">Why not just Claude Code and GitHub?</h2>
      <p class="text-body-lg text-muted-foreground">
        You can — and you should keep using them. AIOS is the layer on top: it wraps the same
        agents in a UI, shared memory, and governance, so your whole team can run them — not just
        the people who live in a terminal.
      </p>
    </div>

    <div class="rounded-xl border border-border overflow-hidden">
      <!-- Header row -->
      <div class="grid grid-cols-2 md:grid-cols-[1.1fr_1fr_1fr] bg-surface">
        <div class="hidden md:block p-5"></div>
        <div class="p-5 text-label text-muted-foreground border-b border-border md:border-l">
          Claude Code + GitHub
        </div>
        <div class="p-5 text-label text-primary border-b border-l border-border">
          AIOS
        </div>
      </div>

      <!-- Rows -->
      {rows.map(({ dimension, plain, aios }) => (
        <div class="grid grid-cols-1 md:grid-cols-[1.1fr_1fr_1fr] border-t border-border">
          <div class="px-5 pt-5 pb-1 md:py-5 text-small font-semibold text-foreground bg-surface md:bg-transparent">
            {dimension}
          </div>
          <div class="px-5 py-3 md:py-5 md:border-l border-border flex items-start gap-2.5 text-small text-muted-foreground">
            <Minus size={16} class="mt-0.5 shrink-0 opacity-40" />
            <span>{plain}</span>
          </div>
          <div class="px-5 pb-5 pt-1 md:py-5 border-l border-border flex items-start gap-2.5 text-small text-foreground">
            <Check size={16} class="mt-0.5 shrink-0 text-accent" />
            <span>{aios}</span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
