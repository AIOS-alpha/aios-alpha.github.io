---
/* Swappable placeholder for screenshots / illustrations / diagrams.
   Real assets land later. Token-driven, dual-mode.
   - `fill`  = absolutely fill the parent (used inside a `.card-media` box that
               owns the aspect ratio — the shadcn-style card-image pattern).
   - `ratio` = own aspect ratio when standalone (ignored when `fill`). */
interface Props {
  label?: string;
  variant?: 'screenshot' | 'illustration' | 'diagram';
  ratio?: string;        // e.g. "16 / 9"
  fill?: boolean;
  class?: string;
}
const {
  label = 'Placeholder',
  variant = 'illustration',
  ratio = '16 / 9',
  fill = false,
  class: className = '',
} = Astro.props;
---

<div
  class={`ph ph--${variant}${fill ? ' ph--fill' : ''} ${className}`}
  style={`--ph-ratio:${ratio}`}
  role="img"
  aria-label={`${label} (placeholder)`}
>
  <div class="ph-inner">
    <span class="ph-label">{label}</span>
    <span class="ph-tag">placeholder · {variant}</span>
  </div>
</div>

<style>
  .ph {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ph-ratio);
    border: 1px dashed var(--aios-border-strong);
    border-radius: var(--aios-radius-xl);
    background:
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 9px,
        color-mix(in srgb, var(--aios-fg) 4%, transparent) 9px,
        color-mix(in srgb, var(--aios-fg) 4%, transparent) 10px
      ),
      var(--aios-surface);
    overflow: hidden;
  }
  .ph--screenshot { border-style: solid; }
  /* Fill the parent .card-media box (which owns the aspect ratio + clipping). */
  .ph--fill {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    aspect-ratio: auto;
    border: 0;
    border-radius: 0;
  }
  .ph-inner {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem;
    text-align: center;
  }
  .ph-label {
    font-family: var(--aios-font-display);
    font-size: 1.25rem;
    line-height: 1.2;
    color: var(--aios-fg-secondary);
  }
  .ph-tag {
    font-family: var(--aios-font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--aios-fg-muted);
    border: 1px solid var(--aios-border);
    border-radius: 9999px;
    padding: 2px 9px;
  }
</style>
