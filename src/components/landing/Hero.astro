---
---

<section class="relative min-h-svh flex items-center dot-grid bg-background overflow-hidden">
  <!-- Ambient prism glow behind headline -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="hero-glow"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-20 w-full">
    <div class="max-w-[800px]">

      <!-- Eyebrow badge -->
      <div class="inline-flex items-center mb-8">
        <span class="text-label text-accent bg-[rgba(132,204,22,0.08)] border border-[rgba(132,204,22,0.2)] px-3 py-1 rounded-full">
          Open Source · Built in Public
        </span>
      </div>

      <!-- Display headline -->
      <h1 class="text-display text-foreground mb-6">
        <span class="bg-gradient-prism bg-clip-text text-transparent">AI</span> transformation,<br />built for agentic teams.
      </h1>

      <!-- Subline -->
      <p class="text-body-lg text-muted-foreground mb-10 max-w-[600px]">
        Every person gets a structured agent workspace. The team gets one shared brain to query
        in plain English — through a UI, not just a terminal. You decide what leaves your machine.
        MIT-licensed and self-hosted.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 mb-14">
        <a
          href="/guides/quickstart"
          class="inline-flex items-center bg-primary text-black font-semibold px-5 py-[10px] rounded-md no-underline transition-all duration-200 hover:bg-primary-hover hover:shadow-btn-glow text-small"
        >
          Get the workspace →
        </a>
        <a
          href="https://github.com/AIOS-alpha"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-foreground font-semibold px-5 py-[10px] rounded-md no-underline border border-border-visible transition-all duration-200 hover:bg-white/[0.04] text-small"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Terminal code block -->
      <div class="terminal max-w-[540px]">
        <div class="terminal-header" aria-hidden="true">
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="terminal-dot"></span>
          <span class="text-label text-muted-foreground ml-2">terminal</span>
        </div>
        <div class="terminal-body">
          <div><span class="terminal-prompt">$</span> npx aios-init my-workspace</div>
          <div><span class="terminal-prompt">$</span> cd my-workspace</div>
          <div><span class="terminal-prompt">$</span> aios push --tier team</div>
        </div>
      </div>

    </div>
  </div>
</section>
