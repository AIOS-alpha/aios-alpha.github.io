---
import Screenshot from './Screenshot.astro';
---

<section class="relative min-h-svh flex items-center bg-background">
  <!-- Ambient spotlight glow — desaturated, heavily blurred, slowly drifting.
       No longer clipped (the wrapper is overflow-visible; body clips x). -->
  <div class="absolute inset-x-0 top-[-3rem] flex justify-center pointer-events-none" aria-hidden="true">
    <div class="hero-spotlight aios-spotlight"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20 pt-32 pb-20 w-full">
    <div class="grid lg:grid-cols-[1fr_minmax(0,440px)] gap-12 lg:gap-16 items-center">

      <!-- Left: copy -->
      <div class="max-w-[640px]">

        <!-- Eyebrow — mono micro-label with a single live dot -->
        <div class="inline-flex items-center gap-2 mb-8 text-label text-muted-foreground">
          <span class="size-1.5 rounded-full bg-accent" aria-hidden="true"></span>
          Open source · built in public
        </div>

        <!-- Display headline — solid ink, italic-serif emphasis (no gradient) -->
        <h1 class="text-display text-foreground mb-6 max-w-[18ch]">
          An AI-powered operating system for <span class="serif-italic">agentic teams</span>.
        </h1>

        <!-- Subline -->
        <p class="text-body-lg text-muted-foreground mb-10 max-w-[560px]">
          Every person gets a structured agent workspace. The team gets one shared brain that learns how you work and helps you collaborate. MIT-licensed and self-hosted. You decide what leaves your machine.
        </p>

        <!-- CTAs — black/white pill (prism border on hover) + ghost pill -->
        <div class="flex flex-wrap gap-3 mb-12">
          <a
            href="/guides/quickstart"
            class="btn-prism inline-flex items-center bg-primary text-primary-foreground font-semibold px-6 py-3 rounded-full no-underline transition-colors duration-200 hover:bg-primary-hover text-small"
          >
            Get the workspace →
          </a>
          <a
            href="https://github.com/AIOS-alpha"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-foreground font-semibold px-6 py-3 rounded-full no-underline border border-border-visible transition-colors duration-200 hover:bg-muted hover:border-border-strong text-small"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <!-- Terminal "device" -->
        <div class="terminal max-w-[480px]">
          <div class="terminal-header" aria-hidden="true">
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="text-label terminal-label ml-2">terminal</span>
          </div>
          <div class="terminal-body">
            <div><span class="terminal-prompt">$</span> npx aios-init my-workspace</div>
            <div><span class="terminal-prompt">$</span> cd my-workspace</div>
            <div><span class="terminal-prompt">$</span> aios push --tier team</div>
          </div>
        </div>

      </div>

      <!-- Right: Team Brain home dashboard — light/dark swap on theme -->
      <div class="w-full">
        <Screenshot
          light="/screenshots/team-brain-home-light.webp"
          dark="/screenshots/team-brain-home-dark.webp"
          alt="The AIOS Team Brain home — ask the shared brain in plain English, with KPIs, knowledge growth, and a live activity feed"
          ratio="4 / 5"
          eager
        />
      </div>

    </div>
  </div>
</section>
