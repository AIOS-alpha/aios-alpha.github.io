---
---

<section class="relative py-24 md:py-36 bg-background overflow-hidden dot-grid">
  <!-- Faint spotlight echo of the hero — bookends the page, stays atmospheric -->
  <div class="absolute inset-x-0 top-1/2 -translate-y-1/2 flex justify-center overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="hero-spotlight aios-spotlight" style="opacity: calc(var(--w-spotlight-opacity) * 0.7);"></div>
  </div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6 md:px-12 lg:px-20 text-center">
    <span class="text-label text-muted-foreground block mb-6">Open source</span>
    <h2 class="text-heading-2 text-foreground mb-6 mx-auto max-w-[640px]">
      Get your workspace running today.
    </h2>
    <p class="text-body-lg text-muted-foreground mb-10 mx-auto max-w-[480px]">
      Open source. Self-hosted. No vendor lock-in.
    </p>
    <a
      href="/guides/quickstart"
      class="inline-flex items-center bg-primary text-primary-foreground font-semibold px-8 py-4 rounded-full no-underline transition-colors duration-200 hover:bg-primary-hover text-body"
    >
      Get the workspace →
    </a>
  </div>
</section>
