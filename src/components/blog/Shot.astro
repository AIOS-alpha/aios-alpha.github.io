---
// A framed product screenshot for blog posts. Shows the light variant in light
// mode and the dark variant in dark mode (toggled by the `.dark` class on <html>,
// which ThemeBootstrap sets before paint). Substack/importers pick up the light
// <img> (first in the DOM). Expects <src>-light.webp and <src>-dark.webp.
interface Props {
	src: string;
	alt: string;
	caption?: string;
	width?: number;
	height?: number;
}
const { src, alt, caption, width, height } = Astro.props;
---

<figure class="shot not-prose">
	<div class="shot-frame">
		<img
			src={`${src}-light.webp`}
			alt={alt}
			width={width}
			height={height}
			loading="lazy"
			decoding="async"
			class="shot-img shot-light"
		/>
		<img
			src={`${src}-dark.webp`}
			alt=""
			aria-hidden="true"
			width={width}
			height={height}
			loading="lazy"
			decoding="async"
			class="shot-img shot-dark"
		/>
	</div>
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.shot {
		margin: 2.75rem 0;
	}
	.shot-frame {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-xl);
		overflow: hidden;
		background: var(--color-surface);
	}
	.shot-img {
		display: block;
		width: 100%;
		height: auto;
	}
	.shot-dark {
		display: none;
	}
	:global(html.dark) .shot-light {
		display: none;
	}
	:global(html.dark) .shot-dark {
		display: block;
	}
	.shot figcaption {
		margin-top: 0.85rem;
		text-align: center;
		font-family: var(--font-sans);
		font-size: 0.85rem;
		line-height: 1.5;
		color: var(--color-muted-foreground);
	}
</style>
